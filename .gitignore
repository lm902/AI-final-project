# ── Datasets (too large for Git) ─────────────────────────────
# Igonre everything in data
data/*

# But allow .txt files
!data/*.txt

# ── Model weights & checkpoints ──────────────────────────────
weights/
checkpoints/
*.pth
*.pt
*.ckpt
*.h5

# ── Output figures & results ─────────────────────────────────
outputs/figures/
outputs/predictions/
outputs/results/
*.png
*.jpg
*.jpeg
# Exception: keep README images
!docs/*.png
!docs/*.jpg

# ── Python cache ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
.Python

# ── Virtual environments ──────────────────────────────────────
venv/
env/
.env/
.venv/

# ── Jupyter checkpoints ───────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── IDE files ─────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.suo
*.user

# ── macOS ─────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Google Colab ──────────────────────────────────────────────
*.ipynb_meta

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
runs/

# ── Distribution / packaging ─────────────────────────────────
dist/
build/
*.egg-info/
